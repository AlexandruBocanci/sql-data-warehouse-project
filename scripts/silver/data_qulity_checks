/* Checking the data quality of the tables from the silver layer
   When running the whole code, there should't be any results
   The quality check queries are done based on the transformations that have been done when creating the stored procedure for loading data from the bronze to the silver layer
   If the csv files will be updated in the future with new values, this folder might not be 100% accurate
   
   1. Checking the data quality: crm_cust_info */

-- Checking for duplicates in cst_id
-- Expecting: No result

USE DataWarehouse;

SELECT 
	cst_id,
	count(cst_id)
FROM silver.crm_cust_info
GROUP BY cst_id
HAVING COUNT(cst_id) != 1

-- Checking for duplicates in cst_key
-- Expecting: No result
SELECT 
	cst_key,
	count(cst_key)
FROM silver.crm_cust_info
GROUP BY cst_key
HAVING COUNT(cst_key) != 1

-- Checking for unwanted spaces in  crm_cust_info.cst_firstname, cst_lastname, cst_marital_status, cst_gndr
-- Expecting: No result
SELECT
	cst_firstname,
	cst_lastname,
	cst_marital_status,
	cst_gndr
FROM silver.crm_cust_info
WHERE cst_firstname != TRIM(cst_firstname) OR cst_lastname != TRIM(cst_lastname) OR cst_marital_status != TRIM(cst_marital_status) OR cst_gndr != TRIM(cst_gndr)

-- Checking for bad data quality in cst_marital_status
-- Expecting: No result
SELECT DISTINCT cst_marital_status 
FROM silver.crm_cust_info
WHERE cst_marital_status NOT IN ('Single', 'Married')

-- Checking for bad data quality in cst_gndr
-- Expecting: n/a | Male | Female
SELECT DISTINCT cst_gndr 
FROM silver.crm_cust_info
WHERE cst_gndr NOT IN ('Male', 'Female', 'n/a')

-- Checking for invalid data in cst_create_date
-- Expecting: No result

SELECT 
	cst_create_date
FROM silver.crm_cust_info
WHERE cst_create_date > GETDATE()

------------------------------------------------------------------------------------------------

/* 2. Checking the data quality: crm_prd_info */


-- Checking for duplicates in prd_id
-- Expecting: No result
SELECT 
	prd_id,
	count(prd_id)
FROM silver.crm_prd_info
GROUP BY prd_id
HAVING COUNT(prd_id) != 1

-- Checking for unwanted spaces in prd_key and prd_nm
-- Expecting: No result

SELECT 
	cat_id,
	prd_key
FROM silver.crm_prd_info
WHERE cat_id != TRIM(cat_id) OR prd_key != TRIM(prd_key) OR cat_id NOT LIKE '%_%'

-- Checking for bad data quality in cst_marital_status and cst_gndr
-- Expecting: No result

SELECT DISTINCT cst_gndr 
FROM silver.crm_cust_info
WHERE cst_gndr NOT IN ('Male', 'Female', 'n/a') OR cst_marital_status NOT IN ('Single', 'Married')

-- Checking for invalid prd_cost
-- Expecting: No result

SELECT 
	prd_cost
FROM silver.crm_prd_info
WHERE prd_cost < 0

-- Checking for invalid data in prd_line
-- Expecting: No result

SELECT DISTINCT
	prd_line
FROM silver.crm_prd_info
WHERE prd_line NOT IN ('Mountain','Other Sales','Road','Touring','n/a')

-- Checking for invalid dates in prd_start_dt and prd_end_dt
-- Expecting: No result

SELECT 
	prd_start_dt,
	prd_end_dt
FROM silver.crm_prd_info
WHERE prd_start_dt > GETDATE() OR prd_end_dt > GETDATE()

------------------------------------------------------------------------------------------------

/* 3. Checking the data quality: crm_sales_details */

-- Checking for customer ids that are in silver.crm_sales_details but not in silver.crm_cust_info
-- Expecting: No result

SELECT
	sls_cust_id
FROM silver.crm_sales_details
WHERE sls_cust_id NOT IN (SELECT cst_id FROM silver.crm_cust_info)

-- Checking for product keys that are in silver.crm_sales_details but not in silver.crm_prd_info
-- Expecting: No result
SELECT
	sls_prd_key
FROM silver.crm_sales_details
WHERE sls_prd_key NOT IN (SELECT prd_key FROM silver.crm_prd_info)

-- Checking for invalid prices / sales
-- Expecting: No result
SELECT
	sls_ord_num,
	sls_prd_key,
	sls_sales,
	sls_quantity,
	sls_price
FROM  silver.crm_sales_details
WHERE sls_sales != sls_quantity * ABS(sls_price) OR sls_price != sls_sales / NULLIF(sls_quantity, 0)

-- Checking for invalid dates in silver.crm_sales_details
-- Expecting: No result
SELECT
	sls_order_dt,
	sls_ship_dt,
	sls_due_dt
FROM silver.crm_sales_details
WHERE sls_order_dt > GETDATE() OR sls_ship_dt > GETDATE() OR sls_due_dt > GETDATE() 

